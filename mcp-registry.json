                "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-token>"
              }
            }
          }
        },
        "command": "GITHUB_PERSONAL_ACCESS_TOKEN=<token> npx -y @modelcontextprotocol/server-github"
