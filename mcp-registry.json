        "web"
      ],
      "usageCount": 0,
      "relatedIds": [
        "mcp-fetch"
      ],
      "verified": true,
      "securityLevel": "S2",
      "contributor": "Anthropic",
      "license": "MIT",
      "install": {
        "type": "standalone",
        "cursorConfig": {
          "mcpServers": {
            "playwright": {
              "command": "npx",
              "args": [
                "-y",
                "@playwright/mcp"
              ]
            }
          }
        },
        "claudeConfig": {
          "mcpServers": {
            "playwright": {
              "command": "npx",
              "args": [
                "-y",
